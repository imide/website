---
import BaseLayout from "@layouts/BaseLayout.astro"
import IconButton from "@components/IconButton.astro";
---

<BaseLayout
  title="Download Legcord"
  description="Download Legcord for Windows, macOS, or Linux. Lightweight Discord client with themes, mods, and privacy. Free and open source."
  canonical="/download"
>
  <script is:inline src="/getLatest.js"></script>
  <article class="py-16" aria-labelledby="download-heading">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <header class="text-center mb-12">
        <h1 id="download-heading" class="text-4xl font-bold text-white mb-4">
          <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">Download Legcord</span>
        </h1>
        <p class="text-gray-400 mb-2 max-w-xl mx-auto">
          Pick your platform below. For release notes and older builds, see <a href="https://github.com/Legcord/Legcord/releases" class="text-blue-400 hover:underline">GitHub releases</a>.
        </p>
        <p class="text-gray-500 text-sm">
          Latest version: <span id="latest-version">VERSIONNUM</span>
        </p>
      </header>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <IconButton 
          vectorIcon="/platform-icons/windows.svg" 
          name="Windows" 
          href={`/download/windows`}
          description="For Windows 10 and above"
        />
        <IconButton 
          vectorIcon="/platform-icons/linux.svg" 
          name="Linux" 
          href="/download/linux"
          description="For various Linux distributions"
        />
        <IconButton 
          vectorIcon="/platform-icons/mac.svg" 
          name="macOS" 
          href={`/download/mac`}
          description="For macOS 12 and above"
        />
      </div>
      <section class="mt-16 text-center" aria-labelledby="which-version">
        <h2 id="which-version" class="text-2xl font-semibold text-white mb-4">Not sure which version to choose?</h2>
        <p class="text-gray-300 max-w-2xl mx-auto mb-4">
          Legcord is available for <strong class="text-white">Windows</strong>, <strong class="text-white">Linux</strong>, and <strong class="text-white">macOS</strong>. Choose the download that matches your operating system. 
          If you're unsure, most modern computers use 64-bit (x64) versions.
        </p>
        <p class="text-gray-400 text-sm max-w-2xl mx-auto">
          On Linux you can use the AppImage, .deb, or Flatpak depending on your distro. On Windows and Mac, run the installer and follow the prompts. After installing, open Legcord and log in with your Discord account—then head to <a href="/plugins" class="text-blue-400 hover:underline">Plugins</a> to enable themes and mods.
        </p>
      </section>
    </div>
  </article>
</BaseLayout>
