---
import BaseLayout from "@layouts/BaseLayout.astro"
import Button from "@components/Button.astro";
---

<BaseLayout>
  <div class="bg-gray-900 py-16">
    <div class="container mx-auto px-4 max-w-4xl">
      <h1 class="text-4xl font-bold text-center text-white mb-8">Legcord plugin list</h1>
      <h2 class="text-2xl font-semibold text-white mb-6 text-center">Choose your client mod of choice:</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Button name="Shelter" href="https://shelter.uwu.network/plugins" description="Comes with every Legcord install" />
        <Button name="Vencord" href="https://vencord.dev/plugins#" description="Togglable in Legcord settings" />
      </div>
    </div>
  </div>
</BaseLayout>