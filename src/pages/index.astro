---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import FeatureCard from "@components/FeatureCard.astro";
import ImageModal from "@components/ImageModal.astro";
import Icon from "@components/Icon.astro";

const siteUrl = "https://legcord.app";
const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "SoftwareApplication",
      "name": "Legcord",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "Windows, macOS, Linux",
      "description": "Legcord is a lightweight, open-source Discord client with custom themes, built-in mods, and privacy-first design. Available for Windows, Mac, and Linux.",
      "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
      "url": `${siteUrl}/download`,
      "downloadUrl": `${siteUrl}/download`,
      "author": { "@type": "Organization", "name": "Legcord Team", "url": "https://github.com/Legcord" }
    },
    {
      "@type": "Organization",
      "name": "Legcord",
      "url": siteUrl,
      "sameAs": ["https://github.com/Legcord/Legcord", "https://discord.gg/TnhxcqynZ2"]
    }
  ]
};

---

<BaseLayout
  title="Legcord – Lightweight Discord Client"
  description="Legcord is a lightweight, open-source Discord client for Windows, Mac, and Linux. Custom themes, built-in mods, privacy-first. Download for free."
  image="/logo.png"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>
  <Hero />
  
  <!-- What is Legcord (SEO + intro) -->
  <section class="py-16" aria-labelledby="what-is-legcord">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 id="what-is-legcord" class="text-3xl font-bold text-white mb-6 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">
        What is Legcord?
      </h2>
      <div class="rounded-2xl p-8 border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm">
        <p class="text-gray-300/90 text-lg leading-relaxed mb-4">
          <strong class="text-white">Legcord</strong> is a free, open-source alternative Discord client that works on <strong class="text-white">Windows</strong>, <strong class="text-white">macOS</strong>, and <strong class="text-white">Linux</strong>. It uses the official Discord web app inside an optimized Electron shell, so you get the same servers, messages, and features—with less RAM usage, built-in themes and mods, and stronger privacy. No injectors or separate mod installers are required: download Legcord, log in with your Discord account, and enable the options you want in settings.
        </p>
        <p class="text-gray-400/80 leading-relaxed">
          Whether you're on x64 or <strong class="text-gray-300">ARM64 / AArch64</strong> (including many Linux devices and ARM Windows machines), Legcord aims to give you a lightweight Discord experience with support for <strong class="text-gray-300">Wayland</strong> and X11 on Linux, native-feeling screensharing on Mac, and optional client mods like Shelter and Vencord for themes and plugins.
        </p>
      </div>
    </div>
  </section>
  
  <!-- Why choose Legcord -->
  <section class="py-16 border-y border-white/[0.06]" aria-labelledby="why-choose">
    <div class="container mx-auto px-4">
      <h2 id="why-choose" class="text-3xl md:text-4xl font-bold mb-12 text-center">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">Why choose Legcord?</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 max-w-5xl mx-auto">
        <div class="rounded-xl p-6 text-center border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm hover:border-blue-500/30 hover:bg-white/[0.06] transition-all duration-300 group">
          <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-500/20 group-hover:bg-blue-500/30 transition-colors">
            <Icon name="chart-decreasing" class="h-7 w-7 text-blue-400" />
          </span>
          <h3 class="text-lg font-semibold text-white mb-2">Lightweight</h3>
          <p class="text-gray-400/80 text-sm leading-relaxed">Uses less RAM than the official client. Perfect for gaming and older hardware.</p>
        </div>
        <div class="rounded-xl p-6 text-center border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm hover:border-purple-500/30 hover:bg-white/[0.06] transition-all duration-300 group">
          <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-purple-500/20 group-hover:bg-purple-500/30 transition-colors">
            <Icon name="shield" class="h-7 w-7 text-purple-400" />
          </span>
          <h3 class="text-lg font-semibold text-white mb-2">Privacy-first</h3>
          <p class="text-gray-400/80 text-sm leading-relaxed">Built-in tracker blocking. We don't collect your data.</p>
        </div>
        <div class="rounded-xl p-6 text-center border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm hover:border-indigo-500/30 hover:bg-white/[0.06] transition-all duration-300 group">
          <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-indigo-500/20 group-hover:bg-indigo-500/30 transition-colors">
            <Icon name="gear" class="h-7 w-7 text-indigo-400" />
          </span>
          <h3 class="text-lg font-semibold text-white mb-2">Open source</h3>
          <p class="text-gray-400/80 text-sm leading-relaxed">Audit the code, contribute, or build themes and plugins.</p>
        </div>
        <div class="rounded-xl p-6 text-center border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm hover:border-blue-500/30 hover:bg-white/[0.06] transition-all duration-300 group">
          <span class="mb-4 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-blue-500/20 group-hover:bg-blue-500/30 transition-colors">
            <Icon name="rocket" class="h-7 w-7 text-blue-400" />
          </span>
          <h3 class="text-lg font-semibold text-white mb-2">Zero hassle</h3>
          <p class="text-gray-400/80 text-sm leading-relaxed">No injectors or installers. Download, run, and customize in settings.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">Key Features</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <FeatureCard 
          title="Customizable" 
          description="Customize your Discord experience with themes and transparency options."
          emoji="artist-palette"
          image="/screenshots/transparent.png"
        />
        <FeatureCard 
          title="Built-in Client Mods" 
          description="Enjoy a smooth modded Discord experience without sacrificing performance."
          emoji="feather"
          image="/screenshots/mods.png"
        />
        <FeatureCard 
          title="Cross-Platform" 
          description="Works on Windows, macOS, and Linux, including AArch64 devices."
          emoji="desktop-computer"
          image="/screenshots/vista.png"
        />
      </div>
    </div>
  </section>
  
  <ImageModal id="modal-customizable" image="/screenshots/transparent.png" title="Customizable" />
  <ImageModal id="modal-built-in-client-mods" image="/screenshots/mods.png" title="Built-in Client Mods" />
  <ImageModal id="modal-cross-platform" image="/screenshots/vista.png" title="Cross-Platform" />
  
  <section class="py-20 border-y border-white/[0.06]">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">Legcord is great for...</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
        <FeatureCard 
          title="Casual users"
          description="Legcord is built specifically for ease of use. You no longer have to deal with the hassle of installing mods. Just download, run and pick what suits you the best!"
          emoji="person"
        />
        <FeatureCard 
          title="Gamers"
          description="Are you tired of Discord app taking your precious ram in the background? Try out Legcord, it's much lighter and detects your games like a charm!"
          emoji="video-game"
        />
        <FeatureCard 
          title="Developers"
          description="Legcord is completely open source, you can create themes and plugins for it. It's very hackable and doesn't block you to look what's inside."
          emoji="technologist"
        />
        <FeatureCard 
          title="Linux users"
          description="Are you tired of the official app being sluggish, unresponsive and not working properly? Try out Legcord! It's built with Linux in mind and works flawlessly."
          emoji="penguin"
        />
      </div>
      
      <h2 class="text-3xl font-bold mb-12 text-center text-white">
        <span class="bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">
          Bonus Features
        </span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <FeatureCard 
          title="Made for Privacy™"
          description="Legcord automatically blocks all of Discord's trackers; even without any client mods, you can feel safe and secure! We also don't collect any data from you."
          emoji="shield"
        />
        <FeatureCard 
          title="Much more stable"
          description="Legcord is using a newer build of Electron than the stock Discord app. This means you can have a much more stable and secure experience, along with slightly better performance."
          emoji="check-mark-button"
        />
        <FeatureCard 
          title="Designed for Mac"
          description="Legcord is optimized for macOS, with a native screensharing and a more Mac-like experience. It's optimized for both Apple Sillicon and Intel macs! No more spinning fan when opening Discord."
          emoji="red-apple"
        />
        <FeatureCard 
          title="Audio screenshare"
          description="Legcord has a built-in audio screenshare feature, so you can share your audio with your friends without any hassle. (Linux/Windows only)"
          emoji="speaker-high-volume"
        />
      </div>
    </div>
  </section>

  <!-- Quick start -->
  <section class="py-20 border-t border-white/[0.06]">
    <div class="container mx-auto px-4">
      <h2 class="text-3xl md:text-4xl font-bold mb-12 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">Get started in 3 steps</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-4xl mx-auto">
        <div class="relative flex flex-col items-center text-center group">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-blue-500 to-blue-600 text-white flex items-center justify-center text-2xl font-bold mb-4 shadow-lg shadow-blue-500/25 group-hover:scale-110 transition-transform">1</div>
          <h3 class="text-xl font-semibold text-white mb-2">Download</h3>
          <p class="text-gray-400/80 text-sm mb-4">Pick your platform and grab the latest build from our download page.</p>
          <a href="/download" class="text-blue-400 hover:text-blue-300 font-medium text-sm transition-colors">Go to downloads →</a>
        </div>
        <div class="relative flex flex-col items-center text-center group">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-purple-500 to-purple-600 text-white flex items-center justify-center text-2xl font-bold mb-4 shadow-lg shadow-purple-500/25 group-hover:scale-110 transition-transform">2</div>
          <h3 class="text-xl font-semibold text-white mb-2">Install & run</h3>
          <p class="text-gray-400/80 text-sm mb-4">Install like any other app, then log in with your Discord account.</p>
        </div>
        <div class="relative flex flex-col items-center text-center group">
          <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-indigo-600 text-white flex items-center justify-center text-2xl font-bold mb-4 shadow-lg shadow-indigo-500/25 group-hover:scale-110 transition-transform">3</div>
          <h3 class="text-xl font-semibold text-white mb-2">Customize</h3>
          <p class="text-gray-400/80 text-sm mb-4">Open Legcord settings to enable themes, mods, and transparency.</p>
          <a href="/plugins" class="text-blue-400 hover:text-blue-300 font-medium text-sm transition-colors">Browse plugins →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Legcord vs official Discord (SEO) -->
  <section class="py-16 border-t border-white/[0.06]" aria-labelledby="legcord-vs-discord">
    <div class="container mx-auto px-4 max-w-4xl">
      <h2 id="legcord-vs-discord" class="text-3xl md:text-4xl font-bold mb-10 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">
        Legcord vs official Discord
      </h2>
      <p class="text-gray-400/80 text-center mb-10 max-w-2xl mx-auto">
        Legcord is not a replacement for Discord—it connects to the same Discord servers and uses your existing account. Here's how it differs from the official Discord app.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full border-collapse rounded-xl overflow-hidden border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm" role="table">
          <thead>
            <tr class="border-b border-white/[0.08] bg-white/[0.04]">
              <th class="text-left py-4 px-4 text-white font-semibold">Feature</th>
              <th class="text-left py-4 px-4 text-white font-semibold">Official Discord</th>
              <th class="text-left py-4 px-4 text-white font-semibold">Legcord</th>
            </tr>
          </thead>
          <tbody class="text-gray-300/80 text-sm">
            <tr class="border-b border-white/[0.06]">
              <td class="py-3 px-4">Performance</td>
              <td class="py-3 px-4">Stutters, long load times</td>
              <td class="py-3 px-4 text-blue-400 font-medium">Quick, smooth</td>
            </tr>
            <tr class="border-b border-white/[0.06]">
              <td class="py-3 px-4">Themes & transparency</td>
              <td class="py-3 px-4">Limited</td>
              <td class="py-3 px-4 text-blue-400 font-medium">Built-in</td>
            </tr>
            <tr class="border-b border-white/[0.06]">
              <td class="py-3 px-4">Client mods (Shelter, Vencord)</td>
              <td class="py-3 px-4">Not supported</td>
              <td class="py-3 px-4 text-blue-400 font-medium">Integrated</td>
            </tr>
            <tr class="border-b border-white/[0.06]">
              <td class="py-3 px-4">Tracker blocking</td>
              <td class="py-3 px-4">—</td>
              <td class="py-3 px-4 text-blue-400 font-medium">Default</td>
            </tr>
            <tr class="border-b border-white/[0.06]">
              <td class="py-3 px-4">Open source</td>
              <td class="py-3 px-4">No</td>
              <td class="py-3 px-4 text-blue-400 font-medium">Yes</td>
            </tr>
            <tr>
              <td class="py-3 px-4">Linux / Wayland / ARM64</td>
              <td class="py-3 px-4">Varies</td>
              <td class="py-3 px-4 text-blue-400 font-medium">First-class</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- System requirements -->
  <section class="py-16" aria-labelledby="system-requirements">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 id="system-requirements" class="text-3xl font-bold mb-8 text-center bg-clip-text text-transparent bg-gradient-to-r from-blue-200 to-purple-300">System requirements</h2>
      <div class="rounded-xl p-6 border border-white/[0.08] bg-white/[0.04] backdrop-blur-sm">
        <ul class="space-y-3 text-gray-300/80 text-sm">
          <li class="flex items-start gap-3">
            <span class="text-blue-400 mt-0.5">•</span>
            <span><strong class="text-white">Windows:</strong> Windows 10 or later (64-bit). ARM64 supported.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-purple-400 mt-0.5">•</span>
            <span><strong class="text-white">macOS:</strong> macOS 12 (Monterey) or later. Apple Silicon and Intel.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-indigo-400 mt-0.5">•</span>
            <span><strong class="text-white">Linux:</strong> Modern distro with Electron support. Wayland and X11. x64 and AArch64.</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-blue-400 mt-0.5">•</span>
            <span><strong class="text-white">RAM:</strong> 512 MB minimum; 2 GB or more recommended for a smooth experience.</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-20 bg-gradient-to-r from-blue-600 to-purple-600 border-t border-white/[0.08]">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl lg:text-4xl font-bold text-white mb-4">Ready to try Legcord?</h2>
      <p class="text-white/90 text-lg mb-8 max-w-xl mx-auto">Download for your platform and join our community for support and updates.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a href="/download" class="bg-white text-blue-600 py-3 px-8 rounded-full text-lg font-semibold hover:scale-105 transition duration-300 shadow-lg inline-block">Download now</a>
        <a href="https://discord.gg/TnhxcqynZ2" class="bg-white/10 backdrop-blur-sm text-white py-3 px-8 rounded-full text-lg font-semibold hover:bg-white/20 transition duration-300 border border-white/20 inline-block">Join Discord</a>
      </div>
    </div>
  </section>
</BaseLayout>